generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model MenuItem {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  category    String
  isVeg       Boolean     @default(true)
  isAvailable Boolean     @default(true)
  createdAt   DateTime    @default(now())
  isArchived  Boolean     @default(false)
  
  orderItems  OrderItem[]
  dailyMenus1 DailyMenu[] @relation("Item1")
  dailyMenus2 DailyMenu[] @relation("Item2")
}

model DailyMenu {
  id          String   @id @default(uuid())
  date        DateTime @unique
  item1Id     String
  item2Id     String
  saladNote   String?
  status      String   @default("DRAFT")
  publishedAt DateTime?
  publishedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item1 MenuItem @relation("Item1", fields: [item1Id], references: [id])
  item2 MenuItem @relation("Item2", fields: [item2Id], references: [id])
  
  orders Order[]
}

model Order {
  id                String           @id @default(uuid())
  customerName      String
  customerPhone     String
  address           String
  totalAmount       Float
  status            String           @default("Pending")
  createdAt         DateTime         @default(now())
  customerId        String?
  deliveryPartnerId String?
  dailyMenuId       String?
  paymentMethod     String           @default("COD")
  paymentStatus     String           @default("Pending")
  deliveryZoneId    String?
  deliveryType      String           @default("IN_HOUSE")
  mealSlot          String           @default("LUNCH")
  subscriptionId    String?

  razorpayOrderId   String?
  razorpayPaymentId String?
  deliveredAt       DateTime?
  confirmedAt       DateTime?
  dispatchedAt      DateTime?
  feedback          String?
  preparingAt       DateTime?
  rating            Int?
  complaints        Complaint[]
  customer          Customer?        @relation(fields: [customerId], references: [id])
  deliveryPartner   DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
  items             OrderItem[]
  dailyMenu         DailyMenu?       @relation(fields: [dailyMenuId], references: [id])
  subscription      Subscription?    @relation(fields: [subscriptionId], references: [id])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Float
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
}

model Customer {
  id            String         @id @default(uuid())
  phone         String?        @unique
  email         String?        @unique
  googleId      String?        @unique
  name          String?
  address       String?
  tokenVersion  Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  complaints    Complaint[]
  orders        Order[]
  subscriptions Subscription[]
}

model Subscription {
  id                  String                 @id @default(uuid())
  customerId          String
  mealSlot            String                 @default("LUNCH")
  planType            String
  dietaryPreference   String
  status              String                 @default("Active")
  startDate           DateTime
  endDate             DateTime
  totalTiffins        Int                    @default(0)
  tiffinsDelivered    Int                    @default(0)
  tiffinsRemaining    Int                    @default(0)
  
  paused              Boolean                @default(false)
  pausedAt            DateTime?
  pauseEffectiveFrom  DateTime?
  pausedTotalDays     Int                    @default(0)
  
  paymentMethod       String                 @default("COD")
  paymentStatus       String                 @default("Pending")
  autoRenew           Boolean                @default(false)
  securityDepositPaid Boolean                @default(false)
  securityDepositAmt  Int                    @default(0)
  totalPrice          Float
  
  deliveryZoneId      String                 @default("ZONE_1")
  riderId             String?
  
  cancelledAt         DateTime?
  cancelledBy         String?
  cancellationReason  String?
  
  razorpayOrderId   String?
  razorpayPaymentId String?
  
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  complaints        Complaint[]
  deliveries        SubscriptionDelivery[]
  orders            Order[]
  
  customer          Customer               @relation(fields: [customerId], references: [id])
}

model SubscriptionDelivery {
  id                String           @id @default(uuid())
  subscriptionId    String
  deliveryDate      DateTime         @db.Date
  mealType          String
  status            String           @default("Pending")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deliveryPartnerId String?
  deliveredAt       DateTime?
  confirmedAt       DateTime?
  dispatchedAt      DateTime?
  feedback          String?
  preparingAt       DateTime?
  rating            Int?
  deliveryPartner   DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
  subscription      Subscription     @relation(fields: [subscriptionId], references: [id])
}

model DeliveryPartner {
  id             String                 @id @default(uuid())
  name           String
  phone          String                 @unique
  vehicleDetails String?
  status         String                 @default("Active")
  createdAt      DateTime               @default(now())
  orders         Order[]
  deliveries     SubscriptionDelivery[]
}

model Complaint {
  id             String        @id @default(uuid())
  customerId     String
  orderId        String?
  subscriptionId String?
  category       String
  description    String
  status         String        @default("Open")
  createdAt      DateTime      @default(now())
  resolvedAt     DateTime?
  customer       Customer      @relation(fields: [customerId], references: [id])
  order          Order?        @relation(fields: [orderId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
}

model Holiday {
  id         String   @id @default(uuid())
  date       DateTime @unique
  name       String
  noDelivery Boolean  @default(true)
  notified   Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  reason     String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("STRING") // "BOOLEAN" | "NUMBER" | "STRING" | "JSON"
  updatedAt DateTime @updatedAt
}
